<defs>
  <style>
    @keyframes star1{0%{opacity:0.2}50%{opacity:1}100%{opacity:0.2}}
    @keyframes star2{0%{opacity:1}50%{opacity:0.1}100%{opacity:1}}
    @keyframes floatShip{0%{transform:translateY(0px)}50%{transform:translateY(-6px)}100%{transform:translateY(0px)}}
    @keyframes bullet1{0%{transform:translateX(0);opacity:1}100%{transform:translateX(320px);opacity:0}}
    @keyframes bullet2{0%{transform:translateX(0);opacity:1}100%{transform:translateX(280px);opacity:0}}
    @keyframes bullet3{0%{transform:translateX(0);opacity:1}100%{transform:translateX(300px);opacity:0}}
    @keyframes explode1{0%{r:0;opacity:1}100%{r:18;opacity:0}}
    @keyframes explode2{0%{r:0;opacity:1}100%{r:14;opacity:0}}
    @keyframes explode3{0%{r:0;opacity:1}100%{r:16;opacity:0}}
    @keyframes floatEnemy{0%{transform:translateY(0)}50%{transform:translateY(5px)}100%{transform:translateY(0)}}
    @keyframes thruster{0%{opacity:0.6;transform:scaleX(1)}50%{opacity:1;transform:scaleX(1.3)}100%{opacity:0.6;transform:scaleX(1)}}
    .s1{animation:star1 2.1s ease-in-out infinite}
    .s2{animation:star2 1.7s ease-in-out infinite}
    .s3{animation:star1 3s ease-in-out infinite 0.5s}
    .s4{animation:star2 2.4s ease-in-out infinite 1s}
    .ship{animation:floatShip 3s ease-in-out infinite}
    .b1{animation:bullet1 1.8s linear infinite}
    .b2{animation:bullet2 1.8s linear infinite 0.6s}
    .b3{animation:bullet3 1.8s linear infinite 1.2s}
    .ex1{animation:explode1 1.8s ease-out infinite}
    .ex2{animation:explode2 1.8s ease-out infinite 0.6s}
    .ex3{animation:explode3 1.8s ease-out infinite 1.2s}
    .enemy{animation:floatEnemy 2.5s ease-in-out infinite}
    .thrust{animation:thruster 0.4s ease-in-out infinite;transform-origin:68px 110px}
  </style>
</defs>

